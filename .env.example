# ── Database ─────────────────────────────────────────────────────────────────
# Pooled connection string (used by the app at runtime)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Direct (non-pooled) connection string (used by Prisma migrations)
# On Neon: use the "Direct connection" string from the Neon console.
# On other providers: can be the same as DATABASE_URL.
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require


# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace_with_64_hex_chars

# Superadmin login credentials — stored only in env, never in the database
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=change_me


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be a verified sender in your Resend account.
# Omit to use Resend's sandbox sender (onboarding@resend.dev).
EMAIL_FROM=picks@yourdomain.com


# ── App ───────────────────────────────────────────────────────────────────────
# Full public URL — no trailing slash. Used to build links in emails.
APP_URL=https://yourapp.vercel.app


# ── Cron jobs ─────────────────────────────────────────────────────────────────
# A secret token shared between your app and cron-job.org (or any external
# scheduler). All cron endpoints check this value before processing.
# Generate with: openssl rand -hex 32
# Pass as a query parameter (?secret=...) or Authorization: Bearer header.
CRON_SECRET=replace_with_random_secret
