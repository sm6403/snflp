generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── League (top-level container) ────────────────────────────────────────────

model League {
  id              String   @id @default(cuid())
  name            String
  inviteCode      String   @unique
  requireApproval Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  seasons      Season[]
  userLeagues  UserLeague[]
  adminUsers   AdminUser[]
  settings     LeagueSettings?
  joinRequests LeagueJoinRequest[]
}

model UserLeague {
  id       String   @id @default(cuid())
  userId   String
  leagueId String
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

model LeagueJoinRequest {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
}

model LeagueSettings {
  id                      String  @id @default(cuid())
  leagueId                String  @unique
  mode                    String  @default("live")
  testSeasonId            String?
  testWeekId              String?
  emailRemindersEnabled   Boolean @default(false)
  reminderDayOfWeek       Int     @default(4)
  reminderHourUtc         Int     @default(12)
  reminderMinuteUtc       Int     @default(0)
  reminderOnlyUnsubmitted Boolean @default(false)
  autoResultsEnabled      Boolean @default(false)
  autoResultsDayOfWeek    Int     @default(2)
  autoResultsHourUtc      Int     @default(12)
  autoResultsMinuteUtc    Int     @default(0)
  autoResultsAdvanceWeek  Boolean @default(false)
  autoLockMode            String  @default("off")  // "off" | "all_before_first" | "thursday_split"

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  hashedPassword    String
  alias             String?
  favoriteTeam       String   @default("Los Angeles Rams")
  favoriteTeamLocked Boolean  @default(false)
  disabled           Boolean  @default(true)
  showOnLeaderboard Boolean   @default(true)
  emailReminders    Boolean   @default(true)
  teamTheme         String?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  pickSets          PickSet[]
  lmsPicks          LmsPick[]
  notificationLogs  NotificationLog[]
  divisionMemberships UserDivision[]
  userLeagues       UserLeague[]
  joinRequests      LeagueJoinRequest[]
}

model GlobalSettings {
  id                    String  @id @default("global")
  newUsersStartDisabled Boolean @default(false)
}

model AdminUser {
  id             String    @id @default(cuid())
  username       String    @unique
  hashedPassword String
  disabled       Boolean   @default(false)
  leagueId       String
  loginAttempts  Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?

  league League @relation(fields: [leagueId], references: [id])
}

// ─── Season structure ────────────────────────────────────────────────────────

model Season {
  id               String   @id @default(cuid())
  year             Int
  type             String   @default("regular")    // "regular" | "postseason"
  mode             String   @default("live")        // "live" | "test"
  isCurrent        Boolean  @default(false)
  leagueId         String
  timedAutolocking           Boolean  @default(false)
  ruleFavouriteTeamBonusWin  Boolean  @default(false)
  ruleLMS                    Boolean  @default(false)
  ruleLMSRound               Int      @default(1)
  usesDivisions              Boolean  @default(false)
  parentSeasonId   String?
  parentSeason     Season?  @relation("PostSeason", fields: [parentSeasonId], references: [id])
  childSeasons     Season[] @relation("PostSeason")
  league           League   @relation(fields: [leagueId], references: [id])
  weeks            Week[]
  lmsPicks         LmsPick[]
  divisions        Division[]
  userDivisions    UserDivision[]
  createdAt        DateTime @default(now())

  @@unique([year, type, leagueId])
}

model Week {
  id          String       @id @default(cuid())
  seasonId    String
  number      Int
  label       String
  isCurrent           Boolean      @default(false)
  lockedForSubmission Boolean      @default(false)
  lockAt              DateTime?
  confirmedAt         DateTime?
  season      Season       @relation(fields: [seasonId], references: [id])
  games            Game[]
  pickSets         PickSet[]
  teamRecords      TeamRecord[]
  lmsPicks         LmsPick[]
  notificationLogs NotificationLog[]
  createdAt        DateTime          @default(now())

  @@unique([seasonId, number])
}

model Team {
  id           String       @id @default(cuid())
  name         String       @unique
  abbreviation String       @unique
  espnId       String       @unique
  homeGames    Game[]       @relation("HomeTeam")
  awayGames    Game[]       @relation("AwayTeam")
  wonGames     Game[]       @relation("WinnerTeam")
  teamRecords  TeamRecord[]
  picks        Pick[]
  lmsPicks     LmsPick[]
  createdAt    DateTime     @default(now())
}

model TeamRecord {
  id     String @id @default(cuid())
  teamId String
  weekId String
  wins   Int    @default(0)
  losses Int    @default(0)
  ties   Int    @default(0)
  team   Team   @relation(fields: [teamId], references: [id])
  week   Week   @relation(fields: [weekId], references: [id])

  @@unique([teamId, weekId])
}

model Game {
  id         String    @id @default(cuid())
  weekId     String
  homeTeamId String
  awayTeamId String
  winnerId   String?
  isTie      Boolean   @default(false)
  gameTime   DateTime?
  lockedAt   DateTime?   // Per-game lock — set by auto-lock cron or admin manual button
  week       Week      @relation(fields: [weekId], references: [id])
  homeTeam   Team      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner     Team?     @relation("WinnerTeam", fields: [winnerId], references: [id])
  picks      Pick[]
  createdAt  DateTime  @default(now())
}

model PickSet {
  id          String    @id @default(cuid())
  userId      String
  weekId      String
  submittedAt DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  user        User      @relation(fields: [userId], references: [id])
  week        Week      @relation(fields: [weekId], references: [id])
  picks       Pick[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, weekId])
}

model Pick {
  id           String   @id @default(cuid())
  pickSetId    String
  gameId       String
  pickedTeamId String?  // null = missed pick (time-locked game, no selection made)
  isCorrect    Boolean?
  editedBy     String?
  pickSet      PickSet  @relation(fields: [pickSetId], references: [id])
  game         Game     @relation(fields: [gameId], references: [id])
  pickedTeam   Team?    @relation(fields: [pickedTeamId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([pickSetId, gameId])
}

model LmsPick {
  id         String   @id @default(cuid())
  userId     String
  weekId     String
  seasonId   String
  teamId     String?  // null = no pick submitted (auto-eliminated)
  lmsRound   Int      @default(1)
  eliminated Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  week   Week   @relation(fields: [weekId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team?  @relation(fields: [teamId], references: [id])

  @@unique([userId, weekId])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminName String   // "superadmin" or the admin's username; stored directly so logs survive account deletion
  action    String   // e.g. "LOCK_WEEK", "EDIT_PICK", "CONFIRM_RESULTS"
  detail    String   // JSON string with contextual data
  leagueId  String?  // optional — null for cross-league superadmin actions
  createdAt DateTime @default(now())
}

model Division {
  id            String         @id @default(cuid())
  seasonId      String
  name          String
  isDefault     Boolean        @default(false)
  season        Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userDivisions UserDivision[]
  createdAt     DateTime       @default(now())

  @@unique([seasonId, name])
}

model UserDivision {
  id         String   @id @default(cuid())
  userId     String
  seasonId   String
  divisionId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  season     Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, seasonId])
}

model NotificationLog {
  id      String   @id @default(cuid())
  userId  String
  weekId  String
  type    String   // "pre_lock_12h" | "thursday_noon"
  sentAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  week    Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([userId, weekId, type])
}
