generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  hashedPassword    String
  alias             String?
  favoriteTeam       String   @default("Los Angeles Rams")
  favoriteTeamLocked Boolean  @default(false)
  disabled           Boolean  @default(true)
  showOnLeaderboard Boolean   @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  pickSets          PickSet[]
  lmsPicks          LmsPick[]
}

model Season {
  id               String   @id @default(cuid())
  year             Int
  type             String   @default("regular")    // "regular" | "postseason"
  mode             String   @default("live")        // "live" | "test"
  isCurrent        Boolean  @default(false)
  timedAutolocking           Boolean  @default(false)
  ruleFavouriteTeamBonusWin  Boolean  @default(false)
  ruleLMS                    Boolean  @default(false)
  parentSeasonId   String?
  parentSeason     Season?  @relation("PostSeason", fields: [parentSeasonId], references: [id])
  childSeasons     Season[] @relation("PostSeason")
  weeks            Week[]
  lmsPicks         LmsPick[]
  createdAt        DateTime @default(now())

  @@unique([year, type])
}

model Week {
  id          String       @id @default(cuid())
  seasonId    String
  number      Int
  label       String
  isCurrent           Boolean      @default(false)
  lockedForSubmission Boolean      @default(false)
  lockAt              DateTime?
  confirmedAt         DateTime?
  season      Season       @relation(fields: [seasonId], references: [id])
  games       Game[]
  pickSets    PickSet[]
  teamRecords TeamRecord[]
  lmsPicks    LmsPick[]
  createdAt   DateTime     @default(now())

  @@unique([seasonId, number])
}

model Team {
  id           String       @id @default(cuid())
  name         String       @unique
  abbreviation String       @unique
  espnId       String       @unique
  homeGames    Game[]       @relation("HomeTeam")
  awayGames    Game[]       @relation("AwayTeam")
  wonGames     Game[]       @relation("WinnerTeam")
  teamRecords  TeamRecord[]
  picks        Pick[]
  lmsPicks     LmsPick[]
  createdAt    DateTime     @default(now())
}

model TeamRecord {
  id     String @id @default(cuid())
  teamId String
  weekId String
  wins   Int    @default(0)
  losses Int    @default(0)
  ties   Int    @default(0)
  team   Team   @relation(fields: [teamId], references: [id])
  week   Week   @relation(fields: [weekId], references: [id])

  @@unique([teamId, weekId])
}

model Game {
  id         String    @id @default(cuid())
  weekId     String
  homeTeamId String
  awayTeamId String
  winnerId   String?
  isTie      Boolean   @default(false)
  gameTime   DateTime?
  week       Week      @relation(fields: [weekId], references: [id])
  homeTeam   Team      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner     Team?     @relation("WinnerTeam", fields: [winnerId], references: [id])
  picks      Pick[]
  createdAt  DateTime  @default(now())
}

model PickSet {
  id          String    @id @default(cuid())
  userId      String
  weekId      String
  submittedAt DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  user        User      @relation(fields: [userId], references: [id])
  week        Week      @relation(fields: [weekId], references: [id])
  picks       Pick[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, weekId])
}

model Pick {
  id           String   @id @default(cuid())
  pickSetId    String
  gameId       String
  pickedTeamId String?  // null = missed pick (time-locked game, no selection made)
  isCorrect    Boolean?
  editedBy     String?
  pickSet      PickSet  @relation(fields: [pickSetId], references: [id])
  game         Game     @relation(fields: [gameId], references: [id])
  pickedTeam   Team?    @relation(fields: [pickedTeamId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([pickSetId, gameId])
}

model AppSettings {
  id           String  @id @default("singleton")
  mode         String  @default("live")
  testSeasonId String?
  testWeekId   String?
}

model AdminUser {
  id             String    @id @default(cuid())
  username       String    @unique
  hashedPassword String
  disabled       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?
}

model LmsPick {
  id         String   @id @default(cuid())
  userId     String
  weekId     String
  seasonId   String
  teamId     String
  eliminated Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  week   Week   @relation(fields: [weekId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, weekId])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminName String   // "superadmin" or the admin's username; stored directly so logs survive account deletion
  action    String   // e.g. "LOCK_WEEK", "EDIT_PICK", "CONFIRM_RESULTS"
  detail    String   // JSON string with contextual data
  createdAt DateTime @default(now())
}
